# labwc autostart

# Desktop shell
qs -c noctalia-shell &

# Authentication agent
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Display configuration
wlr-randr --output eDP-1 --scale 1.3 &

# Output management // Not needed?
# kanshi >/dev/null 2>&1 &

# Night light // activated manually
# wlsunset -S 07:30 -s 18:30 -t 3500 -T 6500 &

# Idle management with lock screen
swayidle -w \
   timeout 1200 'swaylock -f -i ~/Pictures/Wallpapers/wall-violet.jpg' \
   timeout 1500 'wlopm --off eDP-1 && loginctl suspend' \
   resume 'wlopm --on *' \
   before-sleep 'swaylock -f -i ~/Pictures/Wallpapers/wall-violet.jpg' &

# D-Bus session // maybe move to dinit?
[ ! -S "/run/user/1000/bus" ] && /usr/bin/dbus-daemon --session --fork --nopidfile --address=unix:path=/run/user/1000/bus
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=labwc

# Virtual keyboard
voxtype &
