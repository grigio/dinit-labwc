<?xml version="1.0"?>
<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->
<labwc_config>
  <core>
    <perMonitorDesktop>yes</perMonitorDesktop>
  </core>
  <windowSwitcher>
    <osd show="yes" style="thumbnail" />
  </windowSwitcher>
  <resize>
    <minimumArea>16</minimumArea>
    <cornerRange>20</cornerRange>
  </resize>
  <placement>
    <policy>automatic</policy>
  </placement>
  <theme>
    <name>gruvbox-material-dark-blocks</name>
    <cornerRadius>12</cornerRadius>
    <font name="CaskaydiaCove NFP" size="12"/>
    <dropShadows>yes</dropShadows>
    <keepBorder>no</keepBorder>
  </theme>
  <desktops number="4" />
  <cursor theme="Adwaita" size="28"/>
  
  <!-- Keep DP-2 on its desktop when switching on eDP-1 -->
  <desktop>
    <name>1</name>
    <monitor>DP-2</monitor>
    <focusAction>no</focusAction>
  </desktop>
  <desktop>
    <name>2</name>
    <monitor>DP-2</monitor>
    <focusAction>no</focusAction>
  </desktop>
  
  <!-- Assign workspaces to monitors -->
  <desktop>
    <name>1</name>
    <monitor>DP-2</monitor>
  </desktop>
  <desktop>
    <name>2</name>
    <monitor>DP-2</monitor>
  </desktop>
  <desktop>
    <name>3</name>
    <monitor>eDP-1</monitor>
  </desktop>
  <desktop>
    <name>4</name>
    <monitor>eDP-1</monitor>
  </desktop>
  <keyboard>
    <default/>
    
    
	<keybind key="XF86AudioPlay">
	  <action name="Execute">
	    <command>playerctl play-pause</command>
	  </action>
	</keybind>
	<keybind key="XF86AudioPause">
	  <action name="Execute">
	    <command>playerctl play-pause</command>
	  </action>
	</keybind>
	<keybind key="XF86AudioRaiseVolume">
	  <action name="Execute">
	    <command>wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+</command>
	  </action>
	</keybind>
	<keybind key="XF86AudioLowerVolume">
	  <action name="Execute">
	    <command>wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-</command>
	  </action>
	</keybind>
	<keybind key="XF86AudioMute">
	  <action name="Execute">
	    <command>wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle</command>
	  </action>
	</keybind>

    <keybind key="W-Up">
      <action name="ToggleMaximize" direction="both" />
    </keybind>!
    <keybind key="W-Down">
      <action name="ToggleMaximize" direction="both" />
    </keybind>

	<keybind key="W-S-Right">
	  <action name="SendToDesktop" to="right" follow="yes" wrap="yes" />
	   <action name="Focus" />
	</keybind>

	<keybind key="W-S-Left">
	  <action name="SendToDesktop" to="left" follow="yes" wrap="yes" />
	   <action name="Focus" />
	</keybind>
    
    <keybind key="W-w"><action name="Close" /></keybind>

    <keybind key="C-W-Left"><action name="GoToDesktop" to="left" /></keybind>
    <keybind key="C-W-Right"><action name="GoToDesktop" to="right" /></keybind>

    <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
    <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
    <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
    <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>
    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="kgx"/>
    </keybind>
    <keybind key="W-A-r">
      <action name="Execute" command="labwc --reconfigure"/>
    </keybind>
 
    <!--
      Remove a previously defined keybind
      A shorter alternative is <keybind key="W-F4" />
    -->
    <keybind key="W-Space">
      <action name="Execute" command="qs -c noctalia-shell ipc call launcher toggle"/>
    </keybind>

    <keybind key="W-S-w">
      <action name="Execute" command="qs -c noctalia-shell ipc call sessionMenu toggle"/>
    </keybind>
    
	<keybind key="Print">
	  <action name="Execute">
	    <command>sh -c 'grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png'</command>
	  </action>
	</keybind>

	<keybind key="W-n">
	  <action name="Execute">
	    <command>wlsunset -t 2500 -T 3500 -g 0.8</command>
	  </action>
	</keybind>

	<keybind key="W-S-n">
	  <action name="Execute">
	    <command>killall wlsunset</command>
	  </action>
	</keybind>

  </keyboard>
  <mouse>
    <default/>
    <!-- Show a custom menu on desktop right click -->
    <!-- <context name="root"> -->
    <!--   <mousebind button="Right" action="Press"> -->
    <!--     <action name="ShowMenu" menu="some-custom-menu"/> -->
    <!--   </mousebind> -->
    <!-- </context> -->
  </mouse>
  <libinput>
    <device category="touchpad">
      <tapAndDrag>yes</tapAndDrag>
      <dragLock>yes</dragLock>
      <naturalScroll>yes</naturalScroll>
      <threeFingerDrag>no</threeFingerDrag>
    </device>
  </libinput>
</labwc_config>
